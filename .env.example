# ============================================================
# AI Interview Assistant — Environment Configuration
# Copy this file to .env and fill in your values.
# The application runs fully locally with these defaults.
# ============================================================

# ── Application ──────────────────────────────────────────────
NODE_ENV=development
APP_PORT=3001
APP_URL=http://localhost:3001
FRONTEND_URL=http://localhost:3000
CORS_ORIGINS=http://localhost:3000

# ── Database ─────────────────────────────────────────────────
# Local PostgreSQL with pgvector (Docker Compose)
POSTGRES_DB=ai_interview
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/ai_interview

# ── Redis ────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=redis_secret
REDIS_URL=redis://:redis_secret@localhost:6379

# ── JWT ──────────────────────────────────────────────────────
# IMPORTANT: Change these to strong random secrets in production!
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=change-this-to-a-strong-random-secret-minimum-64-chars
JWT_REFRESH_SECRET=change-this-to-a-different-strong-random-secret-minimum-64-chars
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# ── AI Provider (LOCAL by default) ───────────────────────────
# Values: local | bedrock
AI_PROVIDER=local

# ── Ollama (Local LLM) ────────────────────────────────────────
# AIP-C01 note: Ollama is the local equivalent of Amazon Bedrock.
# No API key needed. Models are pulled on first use.
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_DEFAULT_MODEL=llama3
OLLAMA_EMBED_MODEL=nomic-embed-text

# ── Embedding Provider (LOCAL by default) ────────────────────
# Values: local | titan
EMBEDDING_PROVIDER=local

# ── Storage Provider (LOCAL by default) ──────────────────────
# Values: local | s3
STORAGE_PROVIDER=local
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=10

# ── Knowledge Provider (CUSTOM RAG by default) ───────────────
# Values: custom | bedrock-kb
KNOWLEDGE_PROVIDER=custom

# ── MinIO (Local S3-compatible, optional) ────────────────────
MINIO_ENDPOINT=http://localhost:9000
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin123
MINIO_BUCKET=ai-interview-uploads
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001

# ── Rate Limiting ─────────────────────────────────────────────
RATE_LIMIT_TTL=60
RATE_LIMIT_MAX=100

# ── Logging ───────────────────────────────────────────────────
LOG_LEVEL=debug
LOG_FORMAT=json

# ══════════════════════════════════════════════════════════════
# AWS OPTIONAL CONFIGURATION
# Leave blank if not using AWS.
# The application works perfectly without these.
# ══════════════════════════════════════════════════════════════

# ── AWS Credentials ───────────────────────────────────────────
# Recommendation: Use IAM roles in production, not hardcoded keys
AWS_REGION=us-east-1
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=

# ── Amazon Bedrock (optional) ─────────────────────────────────
# Enable by setting AI_PROVIDER=bedrock
# AIP-C01: Bedrock provides managed FM inference with pay-per-token pricing
# Cost: Claude Sonnet ~$3/M input, $15/M output tokens
# AWS_BEDROCK_ENABLED=false
# AWS_BEDROCK_MODEL_ID=anthropic.claude-3-5-sonnet-20241022-v2:0
# AWS_BEDROCK_HAIKU_MODEL_ID=anthropic.claude-3-haiku-20240307-v1:0

# ── Amazon S3 (optional) ──────────────────────────────────────
# Enable by setting STORAGE_PROVIDER=s3
# AWS_S3_BUCKET=
# AWS_S3_REGION=us-east-1

# ── Amazon CloudWatch (optional) ─────────────────────────────
# AWS_CLOUDWATCH_ENABLED=false
# AWS_CLOUDWATCH_LOG_GROUP=/ai-interview-assistant/dev

# ── Bedrock Knowledge Base (optional) ────────────────────────
# Enable by setting KNOWLEDGE_PROVIDER=bedrock-kb
# AWS_BEDROCK_KB_ID=
# AWS_BEDROCK_KB_DATASOURCE_ID=

# ── Titan Embeddings (optional) ──────────────────────────────
# Enable by setting EMBEDDING_PROVIDER=titan
# AWS_TITAN_EMBED_MODEL=amazon.titan-embed-text-v2:0
